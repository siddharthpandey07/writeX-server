# MongoDB connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/dbname

# JWT (must match what auth routes expect)
JWT_SECRET=your-secret-key
JWT_EXPIRE=7d

# Allowed browser origins (comma-separated). No trailing slashes.
# Production Netlify + local Vite:
CLIENT_URL=https://your-app.netlify.app,http://localhost:5173

# Render (and others) set PORT automatically — do not hardcode in production.
