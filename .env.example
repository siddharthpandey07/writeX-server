# MongoDB connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/dbname

# JWT (must match what auth routes expect)
JWT_SECRET=your-secret-key
JWT_EXPIRE=7d

# Allowed browser origins (comma-separated, no spaces after commas is fine)
# Production Netlify + local Vite dev:
CLIENT_URL=https://your-app.netlify.app,http://localhost:5173

# Optional: Railway sets PORT automatically
